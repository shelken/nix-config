{
  "base": {
    "prefix": "base",
    "body": ["{ ... }:", "{", "  $0", "}"],
    "description": "init"
  },
  "darwin": {
    "prefix": "darwin",
    "body": [
      "{ ... }:",
      "{",
      "system.defaults.CustomUserPreferences = {",
      "};",
      "homebrew = {",
      "brews = [",
      "];",
      "casks = [",
      "];",
      "masApps = {",
      "};",
      "};",
      "launchd.user.agents.\"\" = {",
      "command = ''\"\"'';",
      "serviceConfig.RunAtLoad = true;",
      "};",
      "$0",
      "}"
    ],
    "description": "darwinжЁЎжќї"
  },
  "options": {
    "prefix": "options",
    "body": [
      "{ mylib, lib, config, ... }:",
      "let",
      "cfg = config.shelken.${1:name};",
      "in",
      "{",
      "options.shelken.${1:name} = {",
      "enable = mylib.mkBoolOpt false \"Whether or not use to enable.\";",
      "};",
      "config = lib.mkIf cfg.enable {",
      "$0",
      "};",
      "}"
    ],
    "description": "optionsжЁЎжќї"
  },
  "home-file": {
    "prefix": "home-file",
    "body": ["home.file = {", "  $0", "};"],
    "description": "home-file жЁЎжќї"
  },
  "home-packages": {
    "prefix": "home-packages",
    "body": ["home.packages = with pkgs; [", "  $0", "];"],
    "description": "home-packages жЁЎжќї"
  },
  "imports": {
    "prefix": "imports",
    "body": ["imports = (mylib.scanPaths ./.);"],
    "description": "imports жЁЎжќї"
  },
  "home-programs": {
    "prefix": "home-programs",
    "body": ["programs.${1:name} = {", "  enable = true;", "  $0", "};"],
    "description": "home-programs жЁЎжќї"
  },
  "sessionVariables": {
    "prefix": "sessionVariables",
    "body": ["home.sessionVariables = {", "  $0", "};"],
    "description": "sessionVariables жЁЎжќї"
  },
  "shellAliases": {
