  },
  "xdg.configFile": {
    "prefix": "xdg.configFile",
    "body": ["xdg.configFile = {", "  \"$1\" = {", "    source = $2;", "  };", "};"],
    "description": "xdg.configFile жЁЎжќї"
  }
